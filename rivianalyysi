#normalisointi

def normalisoi_pintasana(sana: str) -> str | None:
    """
    Pintasanan normalisointi ennen TTR-laskentaa:
      1. Muunnetaan pienaakkosiksi
      2. Poistetaan johtavat ja pГӨГӨttГӨvГӨt vГӨlimerkit
      3. Unicode NFC -normalisointi (sГӨilyttГӨГӨ ГӨ, Г¶, ГҘ)
      4. HylГӨtГӨГӨn tyhjГӨt ja pelkГӨt ei-aakkosmerkit
    Palauttaa normalisoitu merkkijono tai None (suodatetaan pois).
    """
    sana = sana.lower().strip()
    # poista reunavГӨlimerkit (ei kirjaimet, ei numerot)
    sana = re.sub(r"^[^\w]+|[^\w]+$", "", sana, flags=re.UNICODE)
    sana = unicodedata.normalize("NFC", sana)
    # hylkГӨГӨ jos ei yhtГӨГӨn kirjainta (pelkkГӨ numero tai vГӨlimerkki)
    if not sana or not re.search(r"[a-zГӨГ¶ГҘA-ZГ„Г–Г…]", sana):
        return None
    return sana


#lausepituudet

def laske_lausepituudet(tiedostopolku: str) -> list[int]:
    """
    KГӨy CoNLL-U-tiedoston lГӨpi rivi kerrallaan.
    - Rivi alkaa #  вҶ’ ohita (kommentti)
    - Rivi on tyhjГӨ вҶ’ tallenna laskuri listaan, nollaa laskuri
    - Muuten        вҶ’ pilko tabulaattorilla, tarkista UPOS (indeksi 3)
                      jos ei PUNCT вҶ’ lisГӨГӨ laskuriin
    """
    pituudet = []
    rivilaskuri = 0

    with open(tiedostopolku, "r", encoding="utf-8") as f:
        for rivi in f:
            rivi = rivi.rstrip("\n")

            if rivi.startswith("#"):
                continue

            if rivi == "":
                if rivilaskuri > 0:
                    pituudet.append(rivilaskuri)
                    rivilaskuri = 0
                continue

            sarakkeet = rivi.split("\t")

            # ohita multiword-tokenit (id sisГӨltГӨГӨ vГӨliviivan, esim. "1-2")
            if "-" in sarakkeet[0] or "." in sarakkeet[0]:
                continue

            if len(sarakkeet) > 3:
                upos = sarakkeet[3]
                if upos != "PUNCT":
                    rivilaskuri += 1

    # viimeinen lause jos tiedosto ei pГӨГӨty tyhjГӨГӨn riviin
    if rivilaskuri > 0:
        pituudet.append(rivilaskuri)

    return pituudet


#TTR

def laske_ttr(tiedostopolku: str) -> dict:
    """
    KГӨy CoNLL-U-tiedoston lГӨpi rivi kerrallaan.
    - Rivi alkaa # tai on tyhjГӨ вҶ’ ohita
    - Muuten:
        pilko tabulaattorilla
        UPOS (indeksi 3): jos PUNCT вҶ’ ohita
        tokeneita += 1
        uniikit вҶҗ normalisoitu pintasana (indeksi 1)
        uniikitlemmat вҶҗ lemma (indeksi 2)
    """
    tokeneita = 0
    uniikit = set()
    uniikitlemmat = set()

    with open(tiedostopolku, "r", encoding="utf-8") as f:
        for rivi in f:
            rivi = rivi.rstrip("\n")

            if rivi.startswith("#") or rivi == "":
                continue

            sarakkeet = rivi.split("\t")

            # ohita multiword-tokenit
            if "-" in sarakkeet[0] or "." in sarakkeet[0]:
                continue

            if len(sarakkeet) < 4:
                continue

            upos = sarakkeet[3]
            if upos == "PUNCT":
                continue

            tokeneita += 1

            # pintasana (indeksi 1) вҶ’ normalisointi
            pintasana = sarakkeet[1] if len(sarakkeet) > 1 else ""
            norm = normalisoi_pintasana(pintasana)
            if norm:
                uniikit.add(norm)

            # lemma (indeksi 2)
            lemma = sarakkeet[2] if len(sarakkeet) > 2 else ""
            if lemma and lemma != "_":
                uniikitlemmat.add(lemma.lower())

    ttr  = len(uniikit)      / tokeneita if tokeneita > 0 else 0
    ttr2 = len(uniikitlemmat) / tokeneita if tokeneita > 0 else 0

    return {
        "tokeneita":      tokeneita,
        "uniikit_norm":   len(uniikit),
        "uniikit_lemma":  len(uniikitlemmat),
        "ttr":            round(ttr, 4),
        "ttr2":           round(ttr2, 4),
    }


#frekvenssit

def laske_frekvenssit(tiedostopolku: str) -> tuple[dict, dict, int]:
    """
    KГӨy CoNLL-U-tiedoston lГӨpi rivi kerrallaan.
    Laskee:
      - sanafrekvenssi: perusmuotoisten sanojen esiintymismГӨГӨrГӨt
      - posmГӨГӨrГӨt:      sanaluokkien esiintymismГӨГӨrГӨt (PUNCT mukaan lukien)
      - kaikki_postokenit: tokenien kokonaismГӨГӨrГӨ (PUNCT mukana %)
    """
    sanafrekvenssi = defaultdict(int)
    posmГӨГӨrГӨt = defaultdict(int)
    kaikki_postokenit = 0

    with open(tiedostopolku, "r", encoding="utf-8") as f:
        for rivi in f:
            rivi = rivi.rstrip("\n")

            if rivi.startswith("#") or rivi == "":
                continue

            sarakkeet = rivi.split("\t")

            # ohita multiword-tokenit
            if "-" in sarakkeet[0] or "." in sarakkeet[0]:
                continue

            if len(sarakkeet) < 4:
                continue

            # lemmafrekvenssi (indeksi 2), ohitetaan PUNCT
            upos  = sarakkeet[3]
            lemma = sarakkeet[2] if len(sarakkeet) > 2 else "_"

            if upos != "PUNCT" and lemma != "_":
                sanafrekvenssi[lemma.lower()] += 1

            # sanaluokkafrekvenssi вҖ” PUNCT lasketaan mukaan jakaumaan
            if upos and upos != "_":
                posmГӨГӨrГӨt[upos] += 1
                kaikki_postokenit += 1

    return dict(sanafrekvenssi), dict(posmГӨГӨrГӨt), kaikki_postokenit


#

def chi_square_sanaluokat(pos1: dict, pos2: dict,
                           nimi1: str, nimi2: str) -> tuple[pd.DataFrame, float, float, int]:
    kaikki_upos = sorted(set(pos1) | set(pos2))
    f1 = [pos1.get(u, 0) for u in kaikki_upos]
    f2 = [pos2.get(u, 0) for u in kaikki_upos]

    chi2, p, dof, _ = chi2_contingency([f1, f2])

    df = pd.DataFrame({
        "upos":  kaikki_upos,
        nimi1:   f1,
        nimi2:   f2,
        "chi2":  round(chi2, 4),
        "p_arvo": round(p, 6),
        "df":    dof,
    })
    return df, chi2, p, dof


