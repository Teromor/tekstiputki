def lataa_conllu_urlista(url: str) -> str:
    """
    Hakee CoNLL-U-tiedoston URL:sta ja tallentaa vГӨliaikaiseen tiedostoon.
    Palauttaa vГӨliaikaisen tiedoston polun.
    """
    print(f"  Haetaan: {url}")
    response = requests.get(url)
    response.raise_for_status()
    response.encoding = "utf-8"

    tmp = tempfile.NamedTemporaryFile(mode="w", suffix=".conllu",
                                      encoding="utf-8", delete=False)
    tmp.write(response.text)
    tmp.close()
    return tmp.name


